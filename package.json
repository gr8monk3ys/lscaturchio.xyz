{
  "name": "lscaturchio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint src scripts e2e --max-warnings 0",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "env -u FORCE_COLOR -u NO_COLOR playwright test --project=chromium",
    "test:e2e:all": "env -u FORCE_COLOR -u NO_COLOR PLAYWRIGHT_INCLUDE_WEBKIT=1 playwright test",
    "test:e2e:ui": "env -u FORCE_COLOR -u NO_COLOR playwright test --ui --project=chromium",
    "smoke:chat": "node scripts/smoke-chat.mjs",
    "smoke:chat:prod": "node scripts/smoke-chat.mjs --base-url https://lscaturchio.xyz --attempts 30 --interval-ms 20000",
    "eval:chat": "tsx scripts/eval-chat.ts",
    "predeploy": "bun run lint && bun run typecheck && bun run test && bun run build && bun run test:e2e",
    "knip": "knip",
    "db:migrate": "tsx scripts/run-neon-migration.ts",
    "generate-embeddings": "tsx scripts/generate-embeddings.ts",
    "generate-tts-openai": "tsx scripts/generate-openai-tts.ts",
    "generate-audio-manifest": "tsx scripts/generate-audio-manifest.ts",
    "generate-matisse-covers": "node scripts/generate-matisse-covers.mjs",
    "audit-media": "node scripts/audit-media-assets.mjs",
    "generate-project-logos": "node scripts/generate-project-logos.mjs",
    "suggest-internal-links": "tsx scripts/suggest-internal-links.ts",
    "send-webmentions": "tsx scripts/send-webmentions.ts",
    "perf:lighthouse": "npx -y @lhci/cli@0.15.x autorun --config=.lighthouserc.json",
    "generate-blog-provenance": "tsx scripts/generate-blog-provenance.ts"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@neondatabase/serverless": "^1.1.0",
    "@next/mdx": "^16.2.10",
    "@radix-ui/react-accordion": "^1.2.17",
    "@radix-ui/react-avatar": "^1.2.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@sentry/nextjs": "^10.67.0",
    "@tabler/icons-react": "^3.45.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/typography": "^0.5.20",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "19.2.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-glob": "^3.3.3",
    "feed": "^5.2.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.577.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "openai": "^6.48.0",
    "postcss": "^8.5.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-prism-plus": "^2.0.2",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.10.0",
    "@testing-library/react": "^16.3.2",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "9.39.2",
    "eslint-config-next": "^16.2.10",
    "happy-dom": "^20.11.0",
    "knip": "^6.27.0",
    "tsx": "^4.23.1",
    "vitest": "^4.1.10"
  }
}
